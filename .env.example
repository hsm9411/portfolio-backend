# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/postgres?schema=portfolio

# ========================================
# Supabase Configuration (OAuth 전환)
# ========================================
# Supabase Project URL
SUPABASE_URL=https://vcegupzlmopajpqxttfo.supabase.co

# Supabase Anon (Public) Key - Frontend용
# Dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your_supabase_anon_key_from_dashboard

# Supabase JWT Secret - Backend JWT 검증용
# Dashboard → Settings → API → Project API keys → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_from_dashboard

# ========================================
# JWT Configuration (Local Auth용)
# ========================================
# Local 로그인 전용 JWT Secret (Supabase와 별도)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ========================================
# OAuth Configuration (Deprecated - Supabase OAuth 사용)
# ========================================
# Supabase OAuth 사용 시 아래 설정은 불필요
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=

# ========================================
# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=600

# ========================================
# Server Configuration
# ========================================
PORT=3000
NODE_ENV=development

# CORS: 여러 도메인은 콤마로 구분
# 예: http://localhost:5173,https://yourapp.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================================
# Frontend URL
# ========================================
FRONTEND_URL=http://localhost:5173

# ========================================
# Admin Configuration
# ========================================
ADMIN_EMAIL=your_admin_email@example.com
